{
  "name": "dsa-perfusion-analyzer",
  "private": true,
  "version": "1.0.0",
  "description": "DSA 数字减影血管造影灌注参数分析系统",
  "author": "sccsbc",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vue-tsc -b && vite build",
    "build:electron": "npm run build && electron-builder",
    "build:electron:mac": "npm run build && electron-builder --mac",
    "build:electron:win": "npm run build && electron-builder --win",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vueuse/core": "^14.3.0",
    "axios": "^1.16.0",
    "echarts": "^6.0.0",
    "naive-ui": "^2.44.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.32",
    "vue-echarts": "^8.0.1",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "concurrently": "^9.2.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vue-tsc": "^3.2.7",
    "wait-on": "^9.0.6"
  },
  "build": {
    "appId": "com.sccsbc.dsa-perfusion-analyzer",
    "productName": "DSA 灌注分析系统",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!data/**",
          "!__pycache__/**",
          "!.pytest_cache/**"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.medical",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
